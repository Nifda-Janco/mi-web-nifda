version: '3.8'

services:
  db:
    image: mysql:8.0
    container_name: mysql_db
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root123
      MYSQL_DATABASE: mi_sitio
      MYSQL_USER: usuario
      MYSQL_PASSWORD: password123
    ports:
      - "3307:3306"
    volumes:
      - ./sql/init.sql:/docker-entrypoint-initdb.d/init.sql
      - db_data:/var/lib/mysql

  php:
    image: php:8.2-apache
    container_name: php_apache
    restart: always
    ports:
      - "8081:80"
    volumes:
      - ./src:/var/www/html
    depends_on:
      - db
    build:
      context: .
      dockerfile: Dockerfile

volumes:
  db_data: